-- PostgreSQL initialization script
-- Note: CREATE DATABASE cannot run inside transactions (DO blocks)
-- This script must be executed by psql, which handles each statement separately

-- Create user if it doesn't exist
DO $$
BEGIN
    IF NOT EXISTS (
        SELECT FROM pg_roles WHERE rolname = 'user'
    ) THEN
        CREATE ROLE my_user WITH LOGIN PASSWORD 'password';
    END IF;
END
$$;

-- Create development database (if not exists)
-- Note: PostgreSQL doesn't support "IF NOT EXISTS" for CREATE DATABASE
-- The docker-entrypoint-initdb.d will execute this, and it's safe to run multiple times
-- If database exists, it will error but that's okay - the init script continues
CREATE DATABASE bd_development;

-- Create production database (if not exists)
CREATE DATABASE bd_production;

-- Grant privileges
GRANT ALL PRIVILEGES ON DATABASE bd_development TO my_user;
GRANT ALL PRIVILEGES ON DATABASE bd_production TO my_user;