#To access the container:
#docker exec -it pgdevelopment bash
#psql -h $POSTGRES_HOST -U $POSTGRES_USER -d $POSTGRES_DB 
#en caso que la BD no se haya creado y necesito entrar al catalogo default:
#psql -h $POSTGRES_HOST -U $POSTGRES_USER -d postgres

# backup data directory (from host OS - data is directly accessible):
# tar czf backups/pgdbserver_data_$(date +%Y%m%d_%H%M%S).tar.gz -C /opt/hftamayo/boabsences/data .
# Or using docker (if you prefer):
# docker run --rm -v /opt/hftamayo/boabsences/data:/data -v $(pwd)/backups:/backup alpine tar czf /backup/pgdbserver_data_$(date +%Y%m%d_%H%M%S).tar.gz -C /data .

# restore data directory (from host OS):
# Stop container first: docker stop pgdbserver
# cd /opt/hftamayo/boabsences/data && rm -rf * && tar xzf /path/to/backup/pgdbserver_data_backup.tar.gz
# Start container: docker start pgdbserver
# Or using docker:
# docker run --rm -v /opt/hftamayo/boabsences/data:/data -v $(pwd)/backups:/backup alpine sh -c "cd /data && rm -rf * && tar xzf /backup/pgdbserver_data_backup.tar.gz"    

#Bind mount management (data is on host OS):
# List host directory:
# ls -la /opt/hftamayo/boabsences/data
#
# Check disk usage:
# du -sh /opt/hftamayo/boabsences/data
#
# Copy data to another location (e.g., NAS/SAN):
# rsync -av /opt/hftamayo/boabsences/data/ /mnt/nas/backup/postgres-data/
#
# Mount NAS/SAN location:
# First, mount NAS/SAN to host: mount -t nfs nas-server:/path /mnt/nas
# Then use in docker run: -v /mnt/nas/postgres-data:/var/lib/postgresql/data 
# Setup host directory (run before first container start):
# Local directory:
# mkdir -p /opt/hftamayo/boabsences/data
# chown -R 999:999 /opt/hftamayo/boabsences/data  # PostgreSQL user in container

# Or mount NAS/SAN first, then create directory:
# mount -t nfs nas-server:/databases /mnt/nas
# mkdir -p /mnt/nas/boabsenses-postgres-data
# chown -R 999:999 /mnt/nas/boabsenses-postgres-data